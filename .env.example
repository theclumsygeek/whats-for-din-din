# Copy to .env.local and fill in from your Supabase project (Settings -> API).
# These are safe to expose in the client bundle: the anon key is public by design
# and the database is protected by Row-Level Security + auth.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_YOUR-PUBLISHABLE-KEY
SUPABASE_SECRET_KEY=sb_secret_YOUR-SECRET-KEY